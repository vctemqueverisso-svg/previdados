{
  "name": "previdados",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @previdados/api run start:dev",
    "dev:web": "npm --workspace @previdados/web run dev",
    "build": "npm-run-all build:api build:web",
    "build:api": "npm --workspace @previdados/api run build",
    "build:web": "npm --workspace @previdados/web run build",
    "db:migrate": "npm --workspace @previdados/api run prisma:migrate",
    "db:seed": "npm --workspace @previdados/api run prisma:seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
